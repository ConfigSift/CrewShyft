NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123!

# Platform admin user IDs (comma-separated Supabase auth UUIDs). Users in this list
# can access /admin routes. Leave blank to disable admin access entirely.
ADMIN_AUTH_USER_IDS=

# Stripe Billing
# Set NEXT_PUBLIC_BILLING_ENABLED=true to activate billing checks in middleware and UI.
NEXT_PUBLIC_BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price & promo IDs (test values shown — swap for live IDs in production)
STRIPE_PRICE_PRO_MONTHLY=price_1T6iS4RnRapcy8XbHPGF0PIh
STRIPE_PRICE_PRO_YEARLY=price_1T6iTfRnRapcy8XbCH4udGfq
STRIPE_COUPON_INTRO_MONTHLY=CREWSHYFTPRO1
STRIPE_COUPON_INTRO_YEARLY=CREWSHYFTPROANNUAL1
# Legacy monthly fallback (optional): still supported if STRIPE_COUPON_INTRO_MONTHLY is unset
STRIPE_COUPON_INTRO=CREWSHYFTPRO1

# Debug / dev routes
# Set DEBUG_API_ENABLED=true to enable debug API routes locally (e.g. /api/debug-whoami,
# /api/debug-auth-audit). These routes are blocked in production regardless of this flag.
# Add this to .env.local — never commit a .env file with this set to true.
DEBUG_API_ENABLED=false
